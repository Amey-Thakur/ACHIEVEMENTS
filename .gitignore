.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
ehthumbs_vista.db
[Dd]esktop.ini
Thumbs.db
$RECYCLE.BIN/

# Temporary and Backup Files
*.bak
*.swp
*.swo
*.tmp
*~

# Archival Extraction Artifacts
__MACOSX/

# Local Configuration
.env
.env.local

# IDE and Editor Data
.vscode/
.idea/
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?
